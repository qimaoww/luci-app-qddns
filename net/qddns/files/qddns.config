config qddns 'main'
	option enabled '1'
	option log_dir '/var/log/qddns'
	option state_dir '/var/run/qddns'
	option listen '127.0.0.1:53530'
	option poll_interval '60'
	option timeout '15'
	option log_level 'info'

config source '1'
	option name 'Sample WAN IPv4'
	option type 'local_addr'
	option family 'ipv4'
	option address '1.2.3.4'

config source '2'
	option name 'Sample LAN IPv6 DUID'
	option type 'dhcpv6_duid'
	option duid '0001000130555374bcfce78c41cb'
	option iaid '6bcfce7'
	option lease_file '/tmp/odhcpd.leases'
	option prefix_filter '240e:'
	option hostname_hint 'DESKTOP-DVAVJOS'

config source '3'
	option name 'Sample LAN IPv6 MAC'
	option type 'dhcpv6_mac'
	option mac 'bc:fc:e7:8c:41:cb'
	option lease_file '/tmp/odhcpd.leases'
	option prefix_filter '240e:'
	option hostname_hint 'DESKTOP-DVAVJOS'

config provider '4'
	option name 'Sample Cloudflare'
	option type 'cloudflare'
	option api_token 'replace-me'

config provider '5'
	option name 'Sample DNSPod'
	option type 'dnspod'
	option secret_id 'replace-me'
	option secret_key 'replace-me'

config provider '6'
	option name 'Sample Aliyun'
	option type 'aliyun'
	option access_key_id 'replace-me'
	option access_key_secret 'replace-me'

config provider '7'
	option name 'Sample Custom HTTP'
	option type 'custom_http'
	option url 'https://example.com/ddns/update'
	option method 'POST'
	option headers_json '{"Authorization":"Bearer replace-me"}'
	option body_template '{"domain":"home.example.com","ip":"{{ip}}"}'
	option success_contains 'ok'

config rule '8'
	option name 'Sample Home IPv4'
	option enabled '0'
	option provider '4'
	option source '1'
	option record_type 'A'
	option zone 'example.com'
	option record_name 'home'
	option ttl '300'
	option proxied '0'
	option check_interval '60'
	option force_interval '3600'
	option retry_count '3'
	option retry_backoff '30'

config rule '9'
	option name 'Sample Desktop IPv6'
	option enabled '0'
	option provider '4'
	option source '2'
	option record_type 'AAAA'
	option zone 'example.com'
	option record_name 'desktop'
	option ttl '300'
	option proxied '0'
	option check_interval '60'
	option force_interval '3600'
	option retry_count '3'
	option retry_backoff '30'
