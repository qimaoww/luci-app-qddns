msgstr "规则名称不能为空。"

msgid "This name is shown in provider tables and rule selectors."
msgstr "此名称会显示在提供商表格和规则选择器中。"

msgid "Create a new named provider from a safe template. The name can be changed later."
msgstr "从安全模板创建新的具名提供商。名称之后仍可修改。"

msgid "Copy template values into a new provider without exposing credentials in the main table."
msgstr "将模板值复制到新的提供商中，不在主表格暴露凭据。"

msgid "Configure daemon defaults, source definitions, and provider credentials here. Save and reload after adding providers or sources so dependent rules can pick up the latest choices."
msgstr "在此配置守护进程默认值、来源定义和提供商凭据。新增提供商或来源后，请保存并重新加载，以便依赖规则获取最新选项。"

msgid "Saved sources are available for source probe below and become selectable on the rules page after saving and reloading. Names stay editable."
msgstr "已保存的来源可在下方用于来源探测，并会在保存和重新加载后出现在规则页的可选项中。名称仍可修改。"

msgid "New source name"
msgstr "新增来源名称"

msgid "Enter the source name shown in tables and rule selectors."
msgstr "请输入显示在表格和规则选择器中的来源名称。"

msgid "Name shown in tables, probes, and rule selectors."
msgstr "名称会显示在表格、探测结果和规则选择器中。"

msgid "Saved providers become selectable on the rules page after saving and reloading. Names stay editable."
msgstr "已保存的提供商会在保存和重新加载后出现在规则页的可选项中。名称仍可修改。"

msgid "New provider name"
msgstr "新增提供商名称"

msgid "Enter the provider name shown in tables and rule selectors."
msgstr "请输入显示在表格和规则选择器中的提供商名称。"

msgid "Name shown in tables and rule selectors."
msgstr "名称会显示在表格和规则选择器中。"

msgid "New rule name"
msgstr "新增规则名称"

msgid "Enter the rule name shown in tables, console, and logs."
msgstr "请输入显示在表格、控制台和日志中的规则名称。"

msgid "Name shown in the rule table, console, and log selector."
msgstr "显示在规则表格、控制台和日志选择器中的名称。"

msgid "Guided DDNS rule setup"
msgstr "DDNS 规则添加向导"

msgid "Create a complete DDNS rule in one step. Use the advanced rule table below for later edits."
msgstr "一步创建完整 DDNS 规则。后续编辑可使用下方高级规则表格。"


msgid "Start guided setup"
msgstr "开始引导添加"

msgid "1. Source IP"
msgstr "1. 来源 IP"

msgid "select and probe"
msgstr "选择并探测"

msgid "2. DNS record"
msgstr "2. DNS 记录"

msgid "provider and name"
msgstr "提供商与记录名"

msgid "3. Create"
msgstr "3. 创建"

