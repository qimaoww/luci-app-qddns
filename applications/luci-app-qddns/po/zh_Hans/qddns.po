msgstr "保存并应用"

msgid "No providers available"
msgstr "没有可用提供商"

msgid "No sources available"
msgstr "没有可用来源"

msgid "Create or choose an IP source and probe it, then choose the DNS location."
msgstr "先创建或选择 IP 来源并探测当前 IP，再选择 DNS 位置。"

msgid "Enter provider, zone, and record name."
msgstr "填写提供商、域和记录名。"

msgid "Review the source IP and DNS record before creating the rule."
msgstr "创建规则前请确认来源 IP 和 DNS 记录。"

msgid "Create new source"
msgstr "创建新来源"

msgid "Use saved source"
msgstr "使用已保存来源"

msgid "Source name"
msgstr "来源名称"

msgid "Source type"
msgstr "来源类型"

msgid "Auto"
msgstr "自动"

msgid "IPv4"
msgstr "IPv4"

msgid "IPv6"
msgstr "IPv6"

msgid "Source name is required."
msgstr "来源名称不能为空。"

msgid "Address is required."
msgstr "地址不能为空。"

msgid "WAN/upstream interface is required."
msgstr "WAN/上游接口不能为空。"

msgid "Choose a lease candidate or enter the source values manually."
msgstr "请选择租约候选项，或手动填写来源值。"

msgid "Probe source IP"
msgstr "探测来源 IP"

msgid "Probe source IP before continuing. The source will be saved with the rule."
msgstr "继续前请先探测来源 IP。来源会随规则一起保存。"

msgid "Create or choose a source before continuing."
msgstr "继续前请先创建或选择来源。"

msgid "Probing source IP..."
msgstr "正在探测来源 IP..."

msgid "Source IP detected: %s. Record type was set to %s. The source will be saved with the rule."
msgstr "已探测到来源 IP：%s。记录类型已设为 %s。来源会随规则一起保存。"

msgid "Source IP detected: %s. Record type was set to %s. The saved source will be used for this rule."
msgstr "已探测到来源 IP：%s。记录类型已设为 %s。将使用该已保存来源创建规则。"

msgid "Unable to read source IP. Choose another source or fix the source configuration."
msgstr "无法读取来源 IP。请选择其他来源或修复来源配置。"

msgid "Not previewable in LuCI"
msgstr "LuCI 中不可预览"

msgid "This source type cannot be previewed in LuCI. Confirm the record type manually; the backend will validate it when the rule runs."
msgstr "此来源类型无法在 LuCI 中预览。请手动确认记录类型；后端会在规则运行时继续校验。"

msgid "This source type cannot be previewed in LuCI. Record type was set from the saved source family; the backend will validate it when the rule runs."
msgstr "此来源类型无法在 LuCI 中预览。记录类型已按已保存来源的协议族设置；后端会在规则运行时继续校验。"

msgid "Loading..."
msgstr "正在读取..."

msgid "Source IP is still loading."
msgstr "来源 IP 仍在读取中。"

msgid "Save and reload to read updated source IP."
msgstr "保存并重新加载后读取更新后的来源 IP。"

msgid "Rule name, provider, source, zone, and record name are required."
msgstr "规则名称、提供商、来源、域和记录名不能为空。"

msgid "Provider, source, zone, and record name are required."
msgstr "提供商、来源、域和记录名不能为空。"

msgid "Record type must match the selected source address family."
msgstr "记录类型必须与所选来源的地址协议族匹配。"

msgid "Saving and applying rule..."
msgstr "正在保存并应用规则..."

msgid "Rule has been saved. Applying changes..."
msgstr "规则已保存，正在应用配置..."

msgid "Unable to add the DDNS rule."
msgstr "无法添加 DDNS 规则。"

msgid "Enable after creation"
msgstr "创建后启用"

msgid "Read current DUID"
msgstr "读取当前 DUID"

msgid "Read current MAC"
msgstr "读取当前 MAC"

msgid "Read current DHCPv6 lease candidates, then choose one to fill the DUID source fields."
msgstr "读取当前 DHCPv6 租约候选项，然后选择一个来填充 DUID 来源字段。"

msgid "Read current LAN host candidates, then choose one to fill the MAC source fields."
msgstr "读取当前局域网主机候选项，然后选择一个来填充 MAC 来源字段。"

msgid "Choose a current DUID to fill DUID, IAID, and hostname hint. Keep the WAN interface selected separately."
msgstr "选择当前 DUID 来填充 DUID、IAID 和主机名提示；WAN 接口请单独保持选中。"

msgid "Choose a current MAC to fill MAC, LAN IP identity, and hostname hint. Keep the WAN interface selected separately."
msgstr "选择当前 MAC 来填充 MAC、局域网 IP 识别信息和主机名提示；WAN 接口请单独保持选中。"

msgid "No DHCPv6 leases found."
msgstr "未找到 DHCPv6 租约。"

msgid "No LAN hosts with public IPv6 found."
msgstr "未找到带公网 IPv6 的局域网主机。"

msgid "Fill from this lease"
msgstr "用此租约填充"

msgid "Selected DHCPv6 lease values have been filled. Keep the WAN interface selected separately."
msgstr "已填充所选 DHCPv6 租约值；WAN 接口请单独保持选中。"

msgid "Selected LAN host MAC has been filled. Keep the WAN interface selected separately."
msgstr "已填充所选局域网主机 MAC；WAN 接口请单独保持选中。"

msgid "DHCPv6 leases"
msgstr "DHCPv6 租约"

msgid "LAN hosts"
msgstr "局域网主机"

msgid "Unable to load host candidates."
msgstr "无法加载主机候选项。"

msgid "Hostname"
msgstr "主机名"

msgid "LAN IP"
msgstr "局域网 IP"

msgid "Host interface"
msgstr "主机接口"

msgid "Prefix"
msgstr "前缀"

msgid "Unnamed host"
msgstr "未命名主机"

msgid "Start a short wizard that creates a complete rule with safe defaults. Use the advanced table below for later edits."
msgstr "启动一个简短向导，用安全默认值创建完整规则。下方高级规则表格用于后续编辑。"

msgid "DNS record"
msgstr "DNS 记录"

msgid "Source is required."
msgstr "来源不能为空。"

msgid "Provider, zone, and record name are required."
msgstr "提供商、域和记录名不能为空。"

msgid "Confirm"
msgstr "确认"

msgid "Automatically set from the source IP family."
msgstr "根据来源 IP 协议族自动设置。"

msgid "Saved source"
msgstr "已保存来源"

msgid "Select a saved source. Previewable sources are probed automatically; otherwise A/AAAA follows the saved family or stays manual."
msgstr "选择已保存来源。可预览来源会自动探测；否则 A/AAAA 按已保存的协议族设置，或保留手动选择。"

msgid "WAN prefix source"
msgstr "WAN 前缀来源"

msgid "Choose the WAN/upstream interface that owns the delegated IPv6 prefix. Do not select LAN here."
msgstr "选择拥有下发 IPv6 前缀的 WAN/上游接口。这里不要选择 LAN。"

msgid "Select WAN/upstream interface(s). Verify the real upstream path before probing."
msgstr "选择 WAN/上游接口，可多选。探测前请确认真实上游路径。"

msgid "Select this interface only when it is the WAN/upstream interface for this source."
msgstr "仅当此接口是该来源的 WAN/上游接口时才选择。"

msgid "Choose the WAN/upstream interface whose current address should be published."
msgstr "选择要发布当前地址的 WAN/上游接口。"

msgid "Publish the current address from a WAN/upstream interface."
msgstr "发布 WAN/上游接口上的当前地址。"

msgid "Find a LAN host by DHCPv6 DUID/IAID, then validate its IPv6 against selected WAN/PD prefixes."
msgstr "通过 DHCPv6 DUID/IAID 查找局域网主机，再用所选 WAN/PD 前缀校验它的 IPv6。"

msgid "Find a LAN host by MAC, then validate its IPv6 against selected WAN/PD prefixes."
msgstr "通过 MAC 查找局域网主机，再用所选 WAN/PD 前缀校验它的 IPv6。"

msgid "Use an address you type manually."
msgstr "使用手动填写的地址。"

msgid "LAN host identity"
msgstr "局域网主机身份"

msgid "Lease cards fill the LAN host identity only; the WAN interface remains the prefix source."
msgstr "租约卡片只填充局域网主机身份；WAN 接口仍然是前缀来源。"

msgid "Source definition"
msgstr "来源定义"

msgid "Name the source and choose how QDDNS should read the current IP."
msgstr "命名来源，并选择 QDDNS 读取当前 IP 的方式。"

msgid "Source path"
msgstr "来源路径"

msgid "Choose whether to create a source now or use one already saved."
msgstr "选择现在创建来源，或使用已保存来源。"

msgid "Start with an IP source. For DHCPv6 DUID/MAC, WAN/upstream interfaces use WAN/PD route source prefixes to filter valid LAN host IPv6 addresses; lease candidates only identify the LAN host."
msgstr "先配置 IP 来源。对 DHCPv6 DUID/MAC，WAN/上游接口会使用 WAN/PD 路由来源前缀过滤有效的局域网主机 IPv6；租约候选只用于识别局域网主机。"

